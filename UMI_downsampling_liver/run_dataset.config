params {
  file_type = "rds"
  mode = "run_dataset"
  sc_input = "/data/gent/vo/000/gvo00070/vsc43831/spotless_data/rds/liver_mouseStSt_nuclei_9celltypes_annot_cd45.rds"
  sp_input = "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/data/MouseLiver_UMI_downsampling/*rep[1-3].rds"
  annot = "annot_cd45"
  methods = "rctd"
  skip_metrics = true
  verbose = true
  deconv_args = [rctd: "--doublet_mode doublet --UMI_min 0 --UMI_min_sigma 0"]
  //container_name = 'csangara/sp_rctd:latest'
  //runID_props = "_${params.container_name.split(':')[-1]}"
  //runID_metrics = "_${params.container_name.split(':')[-1]}"
  gpu = false
  outdir = [props: "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/UMI_downsampling/deconv_props",
            metrics: "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/UMI_downsampling/results"]
}

process {

  withName: runRCTD {
      errorStrategy = 'terminate'
      memory = "32 GB" 
      cpus = 8
      time = "3h"
      //container = params.container_name
  }

  withName: runNNLS {
      errorStrategy = 'terminate'
      memory = "24 GB" 
      cpus = 1
      time = "3h"
      // container = params.container_name
  }
}

executor {
    queueSize = 25
    memory = '70 GB'
    cpus = 3
}