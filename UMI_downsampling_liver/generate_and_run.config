params {
  file_type = "rds"
  mode = "generate_and_run"
  sc_input = "/data/gent/vo/000/gvo00070/vsc43831/spotless_data/rds/liver_mouseStSt_nuclei_9celltypes_annot_cd45.rds"
  annot = "annot_cd45"
  methods = "rctd"
  verbose = true
  deconv_args = [rctd: "--doublet_mode doublet --UMI_min 0 --UMI_min_sigma 0"]
  container_name = 'csangara/sp_rctd:latest'
  skip_metrics = true
  // runID_props = "_${params.container_name.split(':')[-1]}"
  // runID_metrics = "_${params.container_name.split(':')[-1]}"
  gpu = false
  outdir = [props: "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/UMI_downsampling_liver/",
            metrics: "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/UMI_downsampling_liver/",
            synthspot: "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/data/MouseLiver_UMI_downsampling"]

  synthspot = [sc_input: "/data/gent/vo/000/gvo00070/vsc43831/spotless_data/rds/liver_mouseStSt_exVivo_9celltypes_annot_cd45.rds",
    clust_var: "annot_cd45",
    type: "adcd",
    reps: 3,
    dataset_id: "1",
    n_regions: 3,
    n_spots_min: 2000,
    n_spots_max: 3000,
    visium_mean: 1000,
    visium_sd: 1000,
    n_cells_min: 1,
    n_cells_max: 2]
}

process {

  withName: generate_synthetic_data {
    errorStrategy = 'retry'
    maxRetries = 2
    memory = { "${task.attempt * 16} GB" }
  }
  

  withName: runRCTD {
      errorStrategy = 'ignore'
      memory = "32 GB" 
      cpus = 8
      time = "4h"
      container = params.container_name
  }
}

executor {
    queueSize = 25
    memory = '64 GB'
    cpus = 24
}