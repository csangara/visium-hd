#!/bin/bash -l
#PBS -l nodes=1:ppn=1:gpus=1
#PBS -l walltime=8:00:00
#PBS -l mem=70gb
#PBS -e logs/
#PBS -o logs/

cd $PBS_O_WORKDIR
module unload Nextflow
module load Nextflow
nextflow run $VSC_DATA_VO_USER/spotless-benchmark/main.nf -profile hpc -c $VSC_DATA_VO_USER/visium-hd/visium_hd_brain/5_1_run_cell2location.config -ansi-log false
