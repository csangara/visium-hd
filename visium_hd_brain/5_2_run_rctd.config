params {
  file_type = "rds"
  mode = "run_dataset"
  sc_input = "/data/gent/vo/000/gvo00070/vsc43831/spatial_datasets/ABA_data/WMB-10Xv3_subset.rds"
  sp_input = "/data/gent/vo/000/gvo00070/vsc43831/spatial_datasets/Visium_HD_MouseBrain/Visium_HD_MouseBrain_008um.rds"
  annot = "class"
  methods = "rctd"
  sampleID = "donor_label"
  verbose = true
  skip_metrics = true
  deconv_args = [rctd: "--doublet_mode doublet"]
  container_name = 'csangara/sp_rctd:latest'
  //runID_props = "_${params.container_name.split(':')[-1]}"
  gpu = false
  outdir = [props: "/data/gent/vo/000/gvo00070/vsc43831/visium-hd/visium_hd_brain"]

}

executor {
  memory = "100 GB"
  cpus = 6
  time = "29h"
}

process {

  executor = 'local'

  withName: runRCTD {
      errorStrategy = 'terminate'
      memory = "96 GB" 
      cpus = 5
      time = "28h"
      container = params.container_name
  }
}